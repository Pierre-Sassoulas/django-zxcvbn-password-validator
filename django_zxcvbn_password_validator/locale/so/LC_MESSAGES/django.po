#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:49
msgid "Use a few words, avoid common phrases"
msgstr "Isticmaal dhowr eray, ka fogow weedhaha caadiga ah"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:51
msgid "No need for symbols, digits, or uppercase letters"
msgstr "Looma baahna calaamado, lambaryo, ama xarfo waaweyn"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:54
msgid "Add another word or two. Uncommon words are better."
msgstr "Ku dar hal eray ama labo. Erayada aan caadiga ahayn ayaa ka wanaagsan."

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:57
msgid "Straight rows of keys are easy to guess"
msgstr "Safafka toosan ee furayaasha waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:60
msgid "Short keyboard patterns are easy to guess"
msgstr "Qaababka gaaban ee kiiboodhka waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:63
msgid "Use a longer keyboard pattern with more turns"
msgstr "Isticmaal qaab kiiboodh oo dheer oo leh leexasho badan"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:65
msgid "Repeats like \"aaa\" are easy to guess"
msgstr "Ku celcelinta sida \"aaa\" waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:67
msgid "Repeats like \"abcabcabc\" are only slightly harder to guess than \"abc\""
msgstr "Ku celcelinta sida \"abcabcabc\" waxay yar ka adag tahay in la malo marka loo eego \"abc\""

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:69
msgid "Avoid repeated words and characters"
msgstr "Ka fogow erayada iyo xarfaha ku celcelis ah"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:71
msgid "Sequences like \"abc\" or \"6543\" are easy to guess"
msgstr "Isku xigxiga sida \"abc\" ama \"6543\" waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:73
msgid "Avoid sequences"
msgstr "Ka fogow isku xigxiga"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:74
msgid "Recent years are easy to guess"
msgstr "Sannadaha dhowaa waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:75
msgid "Avoid recent years"
msgstr "Ka fogow sannadaha dhowaa"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:77
msgid "Avoid years that are associated with you"
msgstr "Ka fogow sannadaha kugu xiran"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:79
msgid "Dates are often easy to guess"
msgstr "Taariikhaha inta badan waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:81
msgid "Avoid dates and years that are associated with you"
msgstr "Ka fogow taariikhaha iyo sannadaha kugu xiran"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:83
msgid "This is a top-10 common password"
msgstr "Tani waa mid ka mid ah 10-da furaha sirta ee ugu caadisan"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:84
msgid "This is a top-100 common password"
msgstr "Tani waa mid ka mid ah 100-da furaha sirta ee ugu caadisan"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:85
msgid "This is a very common password"
msgstr "Tani waa furaha sirta oo aad u caadi ah"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:87
msgid "This is similar to a commonly used password"
msgstr "Tani waxay la mid tahay furaha sirta ee caadi ahaan loo isticmaalo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:89
msgid "A word by itself is easy to guess"
msgstr "Hal eray oo keligiis ah waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:91
msgid "Names and surnames by themselves are easy to guess"
msgstr "Magacyada iyo naanaysyada keligood waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:94
msgid "Common names and surnames are easy to guess"
msgstr "Magacyada iyo naanaysyada caadiga ah waa fudud in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:96
msgid "Capitalization doesn't help very much"
msgstr "Xarfaha waaweyn isticmaalkoodu aad uma caawiyo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:98
msgid "All-uppercase is almost as easy to guess as all-lowercase"
msgstr "Dhammaanteed-waaweyn waa ku dhowayd inay la fududahay sida dhammaanteed-yaryar"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:101
msgid "Reversed words aren't much harder to guess"
msgstr "Erayada la rogay aad uma adka in la malo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:104
msgid "Predictable substitutions like '@' instead of 'a' don't help very much"
msgstr "Bedelaadda la saadaalin karo sida '@' beddelka 'a' aad uma caawiyo"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:134
msgid "less than a second"
msgstr "ka yar hal ilbiriqsi"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:137
#, python-format
msgid "%d second"
msgid_plural "%d seconds"
msgstr[0] "%d ilbiriqsi"
msgstr[1] "%d ilbiriqsi"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:140
#, python-format
msgid "%d minute"
msgid_plural "%d minutes"
msgstr[0] "%d daqiiqad"
msgstr[1] "%d daqiiqadood"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:143
#, python-format
msgid "%d hour"
msgid_plural "%d hours"
msgstr[0] "%d saacad"
msgstr[1] "%d saacadood"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:146
#, python-format
msgid "%d day"
msgid_plural "%d days"
msgstr[0] "%d maalin"
msgstr[1] "%d maalmood"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:149
#, python-format
msgid "%d month"
msgid_plural "%d months"
msgstr[0] "%d bil"
msgstr[1] "%d bilood"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:152
#, python-format
msgid "%d year"
msgid_plural "%d year"
msgstr[0] "%d sannad"
msgstr[1] "%d sannadood"

#: django_zxcvbn_password_validator/translate_zxcvbn_text.py:153
msgid "centuries"
msgstr "qarniyo"

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:71
msgid "Your password exceeds the maximal length of 72 characters."
msgstr "Furaha sirtaada wuxuu ka badan yahay ugu badnaan 72 xaraf."

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:80
msgid "Your password is too guessable:"
msgstr "Furaha sirtaada aad ayuu u fududahay in la malo:"

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:81
#, python-format
msgid "It would take an offline attacker %(time)s to guess it."
msgstr "Waxay ka qaadanaysaa weeraryahan aan khadka ku jirin %(time)s si uu u malo."

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:86
msgid "Warning:"
msgstr "Digniin:"

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:89
msgid "Advice:"
msgstr "Talo:"

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:95
msgid "We expect nothing: you can use any password you want."
msgstr "Waxba kama rabno: waxaad isticmaali kartaa furaha sirta ee aad rabto."

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:96
#, python-format
msgid "We expect a password that cannot be guessed %s"
msgstr "Waxaan rabnaa furaha sirta oo aan la malin karin %s"

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:98
msgid "by your familly or friends."
msgstr "qoyskaaga ama saaxiibbadaa."

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:99
msgid "by attackers online."
msgstr "weeraryadaha khadka tooska ah."

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:100
msgid "without access to our database."
msgstr "iyada oo aan la helin xogteena."

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:101
msgid "without a dedicated team and an access to our database."
msgstr "iyada oo aan jirin koox gaar ah iyo gelitaan xogteena."

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:105
msgid "There is no specific rule for a great password,"
msgstr "Ma jirto xeer gaar ah oo furaha sirta wanaagsan,"

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:106
msgid "however if your password is too easy to guess,"
msgstr "si kastaba ha ahaatee haddii furaha sirtaadu uu aad u fududahay in la malo,"

#: django_zxcvbn_password_validator/zxcvbn_password_validator.py:107
msgid "we will tell you how to make a better one."
msgstr "waxaan kuu sheegi doonaa sida aad mid ka wanaagsan u samayn lahayd."
